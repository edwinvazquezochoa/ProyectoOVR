@page "/Settings/SettingBranches"
@using CurrieTechnologies.Razor.SweetAlert2
@using Ovr.BlazorApp.Extensions
@using Ovr.BlazorApp.Services.Intefaces
@using Ovr.Domain.Models
@using Ovr.Domain.Requests
@using Ovr.Domain.Responses
@inject SweetAlertService SweetAlertService
@inject NavigationManager NavigationManager
@inject IBranchService BranchService
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider autenticacionProvider
@inject HttpClient Http
@inject IJSRuntime _jsService;
@using ClosedXML.Excel;

<div class="card shadow-sm mt-3">
    <div class="card-header bg-body text-bg-info">
        <h3 class="card-title mb-0">Gestión de sucursales</h3>
    </div>
    <div class="card-body">

        <!-- Contenedor flexible para alinear botones -->
        <div class="d-flex justify-content-between mb-3">
            <button class="btn btn-primary" @onclick="ShowAddModal">
                <i class="bi bi-plus-circle me-1"></i> Agregar sucursal
            </button>

            <button class="btn btn-success" @onclick="DownloadExcel">
                <i class="bi bi-file-earmark-excel me-1" disabled="@isDowloading"></i>
                @if (isDowloading)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                    <span>Descargando...</span>
                }
                else
                {
                    <span>Exportar</span>
                }
            </button>
        </div>

        <!-- Campo de búsqueda -->
        <div class="mb-3">
            <input type="text" class="form-control" placeholder="Buscar sucursal..." @bind="searchTerm" @bind:event="oninput" />
        </div>

        <!-- Tabla de sucursales con ordenamiento y paginación -->
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-info">
                    <tr>
                        <th scope="col" class="text-center" @onclick="() => SortByColumn(nameof(Branch.BranchId))">ID ⬆⬇</th>
                        <th scope="col" class="text-center" @onclick="() => SortByColumn(nameof(Branch.BrancheName))">Nombre ⬆⬇</th>
                        <th scope="col" class="text-center" @onclick="() => SortByColumn(nameof(Branch.Address))">Dirección ⬆⬇</th>
                        <th scope="col" class="text-center" @onclick="() => SortByColumn(nameof(Branch.Phone))">Teléfono ⬆⬇</th>
                        <th scope="col" class="text-center">Activo</th>
                        <th scope="col" class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!FilteredBranches.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center">No hay sucursales disponibles.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var branch in FilteredBranches)
                        {
                            <tr>
                                <td class="text-center">@branch.BranchId</td>
                                <td>@branch.BrancheName</td>
                                <td>@branch.Address</td>
                                <td>@branch.Phone</td>
                                <td class="text-center">
                                    <input type="checkbox" checked="@branch.IsActive" disabled />
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-warning btn-sm me-2" @onclick="() => ShowEditModal(branch)">
                                        <i class="bi bi-pencil me-1"></i>
                                    </button>
@*                                     <button class="btn btn-danger btn-sm" @onclick="() => DeleteBranch(branch.BranchId)">
                                        <i class="bi bi-trash me-1"></i>
                                    </button> *@
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="PreviousPage">Anterior</button>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(currentPage == i ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(i)">@i</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="NextPage">Siguiente</button>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Modal con ancho reducido -->
@if (IsModalOpen)
{
    <div class="modal fade show" tabindex="-1">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@ModalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="BrancheName" class="form-label">Nombre de la sucursal</label>
                        <input type="text" id="BrancheName" class="form-control" @bind="SelectedBranch.BrancheName" />
                    </div>
                    <div class="mb-3">
                        <label for="Address" class="form-label">Dirección</label>
                        <input type="text" id="Address" class="form-control" @bind="SelectedBranch.Address" />
                    </div>
                    <div class="mb-3">
                        <label for="Phone" class="form-label">Teléfono</label>
                        <input type="text" id="Phone" class="form-control" @bind="SelectedBranch.Phone" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="IsActive" @bind="SelectedBranch.IsActive">
                        <label class="form-check-label" for="IsActive">Activo</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveBranch">Guardar</button>
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade show"></div>
    </div>
}

@code {
    private List<Branch> Branches = new();
    private string searchTerm = "";
    private string sortColumn = nameof(Branch.BranchId);
    private bool ascending = true;
    private int currentPage = 1;
    private int pageSize = 5;
    private int totalPages => (int)Math.Ceiling((double)Branches.Count / pageSize);
    private Branch SelectedBranch = new();
    private bool IsModalOpen = false;
    private string ModalTitle = "Agregar sucursal";
    private bool isDowloading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _jsService.InvokeVoidAsync("console.log", "ovr.js cargado correctamente.");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
    }
    // Carga la lista de sucursales
    private async Task LoadBranches()
    {
        var response = await BranchService.GetAllAsync();
        if (response?.Code == 200 && response.Data != null)
        {
            Branches = response.Data;
        }
        else
        {
            Branches = new List<Branch>();
        }
    }
    // Guarda (inserta o actualiza) una sucursal
    private async Task SaveBranch()
    {
        ResponseBase<object> response;

        if (SelectedBranch.BranchId == 0) // Crear sucursal
        {
            response = await BranchService.CreateAsync(SelectedBranch);
        }
        else // Actualizar sucursal
        {
            response = await BranchService.UpdateAsync(SelectedBranch.BranchId, SelectedBranch);
        }

        if (response.Code == 200 || response.Code == 201) // Éxito
        {
            await LoadBranches();
            CloseModal();
        }
        else if (response.Code == 409) // Sucursal ya existe
        {
            await SweetAlertService.FireAsync(new SweetAlertOptions
                {
                    Title = "Atención",
                    Text = $"La sucursal '{SelectedBranch.BrancheName}' ya existe.",
                    Icon = SweetAlertIcon.Warning
                });
        }
        else // Otros errores
        {
            await SweetAlertService.FireAsync(new SweetAlertOptions
                {
                    Title = "Error",
                    Text = response.Message,
                    Icon = SweetAlertIcon.Error
                });
        }
    }
    private async Task DeleteBranch(long BranchId)
    {
        await BranchService.DeleteAsync(BranchId);
        await LoadBranches();
    }
    // Filtros y ordenamientos
    private IEnumerable<Branch> FilteredBranches => Branches
        .Where(b => string.IsNullOrEmpty(searchTerm) || b.BrancheName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .OrderBy(b => ascending ? typeof(Branch).GetProperty(sortColumn)?.GetValue(b, null) : null)
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);
    private void SortByColumn(string columnName)
    {
        if (sortColumn == columnName)
        {
            ascending = !ascending;
        }
        else
        {
            sortColumn = columnName;
            ascending = true;
        }
    }
    // Exporta a Excel
    private async Task DownloadExcel()
    {
        isDowloading = true;
        try
        {
            using (var Workbook = new XLWorkbook())
            {
                IXLWorksheet worksheet = Workbook.Worksheets.Add("Sucursales");

                int startRow = 2; // Inicia en la fila 2
                int startCol = 2; // Inicia en la columna 2

                // Título del reporte
                worksheet.Cell(startRow, startCol).Value = "Reporte de Sucursales";
                worksheet.Range(startRow, startCol, startRow, startCol + 4).Merge().Style
                    .Font.SetBold(true)
                    .Font.SetFontSize(14)
                    .Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center)
                    .Fill.SetBackgroundColor(XLColor.LightGray);

                // Encabezados
                worksheet.Cell(startRow + 1, startCol).Value = "Id";
                worksheet.Cell(startRow + 1, startCol + 1).Value = "Nombre";
                worksheet.Cell(startRow + 1, startCol + 2).Value = "Dirección";
                worksheet.Cell(startRow + 1, startCol + 3).Value = "Teléfono";
                worksheet.Cell(startRow + 1, startCol + 4).Value = "Activo";

                worksheet.Range(startRow + 1, startCol, startRow + 1, startCol + 4).Style
                    .Font.SetBold(true)
                    .Font.SetFontColor(XLColor.White)
                    .Fill.SetBackgroundColor(XLColor.BlueGray)
                    .Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center)
                    .Border.SetOutsideBorder(XLBorderStyleValues.Thin)
                    .Border.SetInsideBorder(XLBorderStyleValues.Thin);

                // Llenar la tabla con datos
                for (int fila = 0; fila < Branches.Count; fila++)
                {
                    worksheet.Cell(startRow + 2 + fila, startCol).Value = Branches[fila].BranchId;
                    worksheet.Cell(startRow + 2 + fila, startCol + 1).Value = Branches[fila].BrancheName;
                    worksheet.Cell(startRow + 2 + fila, startCol + 2).Value = Branches[fila].Address;
                    worksheet.Cell(startRow + 2 + fila, startCol + 3).Value = Branches[fila].Phone;

                    var cellActivo = worksheet.Cell(startRow + 2 + fila, startCol + 4);
                    cellActivo.Value = Branches[fila].IsActive ? "SI" : "NO";
                    cellActivo.Style.Alignment.SetHorizontal(XLAlignmentHorizontalValues.Center);
                }

                // Aplicar bordes a la tabla
                worksheet.Range(startRow + 1, startCol, Branches.Count + startRow + 1, startCol + 4).Style
                    .Border.SetOutsideBorder(XLBorderStyleValues.Thin)
                    .Border.SetInsideBorder(XLBorderStyleValues.Thin);

                worksheet.Columns().AdjustToContents();

                using (var memoria = new MemoryStream())
                {
                    Workbook.SaveAs(memoria);
                    var nombreExcel = $"Reporte_Sucursales_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
                    await _jsService.InvokeVoidAsync("window.DescargarExcel", nombreExcel, Convert.ToBase64String(memoria.ToArray()));
                }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error: {ex.Message}");
            await SweetAlertService.FireAsync("Error", ex.Message, SweetAlertIcon.Error);
        }
        finally
        {
            isDowloading = false;
        }
    }
    // Manejo del modal
    private void ShowAddModal()
    {
        SelectedBranch = new Branch();
        ModalTitle = "Agregar sucursal";
        IsModalOpen = true;
    }
    private void ShowEditModal(Branch branch)
    {
        SelectedBranch = new Branch
            {
                BranchId = branch.BranchId,
                BrancheName = branch.BrancheName,
                Address = branch.Address,
                Phone = branch.Phone,
                IsActive = branch.IsActive
            };
        ModalTitle = "Editar sucursal";
        IsModalOpen = true;
    }
    private void CloseModal()
    {
        IsModalOpen = false;
    }
    // Navegación de datos por página
    private void PreviousPage() => currentPage = Math.Max(1, currentPage - 1);
    private void NextPage() => currentPage = Math.Min(totalPages, currentPage + 1);
    private void GoToPage(int page) => currentPage = page;
}
