@page "/Settings/SettingUsers"

@using CurrieTechnologies.Razor.SweetAlert2
@using Ovr.BlazorApp.Extensions
@using Ovr.BlazorApp.Services.Intefaces
@using Ovr.Domain.Models
@using Ovr.Domain.Responses
@inject SweetAlertService SweetAlertService
@inject IUserService UserService
@inject IPersonsServices PersonService
@inject IRoleService RoleService
@inject IJSRuntime JSRuntime
@inject AutenticacionExtension AuthService
@inject IBranchService BranchService

@using ClosedXML.Excel

<div class="card shadow-sm mt-3">
	<div class="card-header bg-body text-bg-info">
		<h3 class="card-title mb-0">Gestión de Usuarios</h3>
	</div>
	<div class="card-body">
		<div class="d-flex justify-content-between mb-3">
			<button class="btn btn-primary" @onclick="ShowAddModal">
				<i class="bi bi-plus-circle me-1"></i> Agregar Usuario
			</button>
			<button class="btn btn-success" @onclick="DownloadExcel">
				<i class="bi bi-file-earmark-excel me-1" disabled="@isDownloading"></i>
				@if (isDownloading)
				{
					<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
					<span>Descargando...</span>
				}
				else
				{
					<span>Exportar</span>
				}
			</button>
		</div>

		<div class="mb-3">
			<input type="text" class="form-control" placeholder="Buscar usuario..." @bind="searchTerm" @bind:event="oninput" />
		</div>

		<div class="table-responsive">
			<table class="table table-striped table-hover">
				<thead class="table-info">
					<tr>
						<th class="text-center">ID</th>
						<th class="text-center">Usuario</th>
						<th class="text-center">Email</th>
						<th>Nombre completo</th>
						<th class="text-center">Rol</th>
						<th class="text-center">Sucursal</th>
						<th class="text-center">Global</th>
						<th class="text-center">Activo</th>
						<th class="text-center">Acciones</th>
					</tr>
				</thead>
				<tbody>
					@if (!PagedUsers.Any())
					{
						<tr>
							<td colspan="9" class="text-center">No hay usuarios disponibles.</td>
						</tr>
					}
					else
					{
						@foreach (var user in PagedUsers)
						{
							<tr>
								<td class="text-center">@user.UserId</td>
								<td>@user.Username</td>
								<td>@user.Email</td>
								<td>@user.FullName</td>
								<td class="text-center">@user.RoleName</td>
								<td class="text-center">@user.BrancheName</td>
								<td class="text-center">
									<input type="checkbox" checked="@user.IsGlobal" disabled />
								</td>
								<td class="text-center">
									<input type="checkbox" checked="@user.IsActive" disabled />
								</td>
								<td class="text-center">
									<button class="btn btn-warning btn-sm me-2" @onclick="() => ShowEditModal(user)">
										<i class="bi bi-pencil me-1"></i>
									</button>
								</td>
							</tr>
						}
					}
				</tbody>
			</table>
		</div>
		<nav>
			<ul class="pagination justify-content-center">
				<li class="page-item @(currentPage == 1 ? "disabled" : "")">
					<button class="page-link" @onclick="PreviousPage">Anterior</button>
				</li>
				@for (int i = 1; i <= totalPages; i++)
				{
					<li class="page-item @(currentPage == i ? "active" : "")">
						<button class="page-link" @onclick="() => GoToPage(i)">@i</button>
					</li>
				}
				<li class="page-item @(currentPage == totalPages ? "disabled" : "")">
					<button class="page-link" @onclick="NextPage">Siguiente</button>
				</li>
			</ul>
		</nav>
	</div>
</div>

@if (IsModalOpen)
{
	<div class="modal fade show" tabindex="-1">
		<div class="modal-dialog modal-lg modal-dialog-centered">
			<div class="modal-content">
				<EditForm Model="SelectedUser" OnValidSubmit="SaveUser">
					<DataAnnotationsValidator />

					<div class="modal-header">
						<h5 class="modal-title">@ModalTitle</h5>
						<button type="button" class="btn-close" @onclick="CloseModal"></button>
					</div>

					<div class="modal-body">
						<ValidationSummary />
						<div class="row g-2">
							<div class="col-md-6">
								<label class="form-label">Usuario</label>
								<InputText class="form-control" @bind-Value="SelectedUser.Username" />
								<ValidationMessage For="@(() => SelectedUser.Username)" />
							</div>
							<div class="col-md-6">
								<label class="form-label">Correo electrónico</label>
								<InputText class="form-control" @bind-Value="SelectedUser.Email" />
								<ValidationMessage For="@(() => SelectedUser.Email)" />
							</div>
							<div class="col-md-6">
								<label class="form-label">Persona</label>
								<InputSelect class="form-select" @bind-Value="SelectedUser.PersonId">
									<option disabled value="0">Seleccione una persona</option>
									@foreach (var person in Persons)
									{
										<option value="@person.PersonId">@person.FullName</option>
									}
								</InputSelect>
								<ValidationMessage For="@(() => SelectedUser.PersonId)" />
							</div>
							<div class="col-md-6">
								<label class="form-label">Rol</label>
								<InputSelect class="form-select" @bind-Value="SelectedUser.RoleId">
									<option disabled value="0">Seleccione un rol</option>
									@foreach (var rol in Roles)
									{
										<option value="@rol.RoleId">@rol.RoleName</option>
									}
								</InputSelect>
								<ValidationMessage For="@(() => SelectedUser.RoleId)" />
							</div>
							<div class="col-md-6">
								<label class="form-label">Sucursal</label>
								<InputSelect class="form-select"
											 @bind-Value="SelectedUser.BranchId"
											 disabled="@(SelectedUser.IsGlobal)">
									<option value="0">-- Seleccione sucursal --</option>
									@foreach (var branch in Branches)
									{
										<option value="@branch.BranchId">@branch.BrancheName</option>
									}
								</InputSelect>
							</div>
							<div class="col-md-6 d-flex align-items-end">
								<div class="form-check">
									<InputCheckbox class="form-check-input"
												   @bind-Value="SelectedUser.IsGlobal"
												   @onchange="OnGlobalChanged" />

									<label class="form-check-label">Global</label>
								</div>
							</div>
							<div class="col-md-6 d-flex align-items-end">
								<div class="form-check">
									<InputCheckbox class="form-check-input" @bind-Value="SelectedUser.IsActive" />
									<label class="form-check-label">Activo</label>
								</div>
							</div>
						</div>
					</div>

					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
						<button type="submit" class="btn btn-primary">Guardar</button>
					</div>
				</EditForm>
			</div>
		</div>
		<div class="modal-backdrop fade show"></div>
	</div>
}

@code {

	private long? sesionUserId;

	private List<User> Users = new();
	private List<User> filteredUsers = new();
	private List<Person> Persons = new();
	private List<Role> Roles = new();
	private List<Branch> Branches = new(); // Lista de sucursales

	private string searchTerm = "";
	private string sortColumn = nameof(User.UserId);
	private bool ascending = true;

	private int currentPage = 1;
	private int pageSize = 5;
	private int totalPages => (int)Math.Ceiling((double)filteredUsers.Count / pageSize);
	private List<User> PagedUsers => filteredUsers
		.Skip((currentPage - 1) * pageSize)
		.Take(pageSize)
		.ToList();

	private User SelectedUser = new();
	private bool IsModalOpen = false;
	private string ModalTitle = "Agregar usuario";
	private bool isDownloading = false;

	protected override async Task OnInitializedAsync()
	{
		sesionUserId = await AuthService.ObtenerUserIdAsync();

		await LoadUsers();
		await LoadPersons();
		await LoadRoles();
		await LoadBranches();
	}

	private void OnGlobalChanged(ChangeEventArgs e)
	{
		bool isGlobalChecked = Convert.ToBoolean(e.Value);
		SelectedUser.IsGlobal = isGlobalChecked;

		if (isGlobalChecked)
			SelectedUser.BranchId = 0; // Limpia la sucursal si es global
	}

	private async Task LoadUsers()
	{
		var response = await UserService.GetUsersAsync();
		Users = response?.Code == 200 && response.Data != null ? response.Data : new();
		ApplyFilterAndSort();
	}

	private async Task LoadPersons()
	{
		var response = await PersonService.GetPersonsAsync();
		Persons = response?.Code == 200 && response.Data != null ? response.Data : new();
	}

	private async Task LoadRoles()
	{
		var response = await RoleService.GetRolesAsync();
		Roles = response?.Code == 200 && response.Data != null ? response.Data : new();
	}
	private async Task LoadBranches()
	{
		var response = await BranchService.GetAllAsync();
		Branches = response?.Code == 200 && response.Data != null ? response.Data : new();
	}
	private void ApplyFilterAndSort()
	{
		var query = Users.Where(u => string.IsNullOrEmpty(searchTerm)
			|| u.Username.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
			|| u.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

		var prop = typeof(User).GetProperty(sortColumn);
		if (prop != null)
		{
			query = ascending
				? query.OrderBy(u => prop.GetValue(u)?.ToString())
				: query.OrderByDescending(u => prop.GetValue(u)?.ToString());
		}

		filteredUsers = query.ToList();

		if (currentPage > totalPages)
			currentPage = totalPages == 0 ? 1 : totalPages;
	}

	private void SortByColumn(string columnName)
	{
		if (sortColumn == columnName)
			ascending = !ascending;
		else
		{
			sortColumn = columnName;
			ascending = true;
		}

		ApplyFilterAndSort();
		StateHasChanged();
	}

	private void PreviousPage()
	{
		currentPage = Math.Max(1, currentPage - 1);
		ApplyFilterAndSort();
	}

	private void NextPage()
	{
		currentPage = Math.Min(totalPages, currentPage + 1);
		ApplyFilterAndSort();
	}

	private void GoToPage(int page)
	{
		currentPage = page;
		ApplyFilterAndSort();
	}

	private void ShowAddModal()
	{
		SelectedUser = new();
		ModalTitle = "Agregar usuario";
		IsModalOpen = true;
	}

	private void ShowEditModal(User user)
	{
		SelectedUser = new User
			{
				UserId = user.UserId,
				Username = user.Username,
				Email = user.Email,
				PersonId = user.PersonId,
				RoleId = user.RoleId,
				IsActive = user.IsActive,
				BranchId = user.BranchId,
				IsGlobal = user.IsGlobal
			};
		ModalTitle = "Editar usuario";
		IsModalOpen = true;
	}

	private void CloseModal() => IsModalOpen = false;

	private async Task SaveUser()
	{
		ResponseBase<object> response;

		if (SelectedUser.UserId == 0)
		{
			SelectedUser.CreatedBy = sesionUserId;
			response = await UserService.CreateUserAsync(SelectedUser);
		}
		else
		{
			SelectedUser.UpdatedBy = sesionUserId;
			response = await UserService.UpdateUserAsync(SelectedUser.UserId, SelectedUser);
		}
		if (response.Code == 200 || response.Code == 201)
		{
			await LoadUsers();
			CloseModal();
		}
		else if (response.Code == 400)
		{
			await SweetAlertService.FireAsync("Atención", response.Message, SweetAlertIcon.Warning);
		}
		else if (response.Code == 409)
		{
			await SweetAlertService.FireAsync("Atención", $"El usuario '{SelectedUser.Username}' ya existe.", SweetAlertIcon.Warning);
		}
		else
		{
			await SweetAlertService.FireAsync("Error", response.Message, SweetAlertIcon.Error);
		}
	}

	private async Task DownloadExcel()
	{
		isDownloading = true;
		try
		{
			using var workbook = new XLWorkbook();
			var sheet = workbook.Worksheets.Add("Usuarios");

			// Encabezados
			sheet.Cell(1, 1).Value = "ID";
			sheet.Cell(1, 2).Value = "Usuario";
			sheet.Cell(1, 3).Value = "Email";
			sheet.Cell(1, 4).Value = "Nombre completo";
			sheet.Cell(1, 5).Value = "Rol";
			sheet.Cell(1, 6).Value = "Sucursal";
			sheet.Cell(1, 7).Value = "Global";
			sheet.Cell(1, 8).Value = "Activo";

			for (int i = 0; i < Users.Count; i++)
			{
				var u = Users[i];
				sheet.Cell(i + 2, 1).Value = u.UserId;
				sheet.Cell(i + 2, 2).Value = u.Username;
				sheet.Cell(i + 2, 3).Value = u.Email;
				sheet.Cell(i + 2, 4).Value = u.FullName;
				sheet.Cell(i + 2, 5).Value = u.RoleName;
				sheet.Cell(i + 2, 6).Value = string.IsNullOrEmpty(u.BrancheName) ? "—" : u.BrancheName;
				sheet.Cell(i + 2, 7).Value = u.IsGlobal ? "SI" : "NO";
				sheet.Cell(i + 2, 8).Value = u.IsActive ? "SI" : "NO";
			}

			sheet.Columns().AdjustToContents();

			using var stream = new MemoryStream();
			workbook.SaveAs(stream);
			var nombreExcel = $"Reporte_Usuarios_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
			await JSRuntime.InvokeVoidAsync("window.DescargarExcel", nombreExcel, Convert.ToBase64String(stream.ToArray()));
		}
		catch (Exception ex)
		{
			await SweetAlertService.FireAsync("Error", ex.Message, SweetAlertIcon.Error);
		}
		finally
		{
			isDownloading = false;
		}
	}

}