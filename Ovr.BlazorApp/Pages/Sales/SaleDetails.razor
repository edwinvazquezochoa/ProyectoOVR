    private decimal CalcularSaldoRestante()
    {
        var total = saleNoteCurrent.Total;
        var abonado = SaleNotePayments.Sum(p => p.AmountPaid);
        var saldo = total - abonado - nuevoPago.AmountPaid;
        return saldo < 0 ? 0 : saldo;
    }



