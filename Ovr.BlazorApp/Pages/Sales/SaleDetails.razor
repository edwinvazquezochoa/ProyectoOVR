    private async Task OnClienteChanged(long newPersonId)
    {
        Console.WriteLine($">>> Cambio de cliente: {newPersonId}");

        if (newPersonId > 0)
        {
            var response = await PersonService.GetByIdAsync(newPersonId);

            if (response.Code == 200 && response.Data != null)
            {
                var p = response.Data;

                saleNote.ClienteNombre = p.FullName;
                saleNote.ClienteTelefono = p.PhoneNumber ?? "";
                saleNote.ClienteEmail = p.Email ?? "";
                saleNote.AddressStreetNumber = p.AddressStreetNumber ?? "";
                saleNote.AddressNeighborhood = p.AddressNeighborhood ?? "";
                saleNote.AddressCity = p.AddressCity ?? "";
                saleNote.AddressState = p.AddressState ?? "";
                saleNote.AddressPostalCode = p.AddressPostalCode?.ToString() ?? "";
            }
        }
        else
        {
            saleNote.ClienteNombre = "";
            saleNote.ClienteTelefono = "";
            saleNote.ClienteEmail = "";
            saleNote.AddressStreetNumber = "";
            saleNote.AddressNeighborhood = "";
            saleNote.AddressCity = "";
            saleNote.AddressState = "";
            saleNote.AddressPostalCode = "";
        }

        // Muy importante para que refresque bien la vista
        await InvokeAsync(StateHasChanged);
    }

