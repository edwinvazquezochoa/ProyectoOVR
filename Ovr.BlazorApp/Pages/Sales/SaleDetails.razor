        saleNoteCurrent.Accessories = accesorios;
        saleNoteCurrent.Payments = SaleNotePayments;
        saleNote = saleNoteCurrent;

        var sumaAbonos = SaleNotePayments.Sum(p => p.AmountPaid);
        var totalNota = saleNote.Total;

        // if (sumaAbonos != totalNota)
        // {
        //     await SweetAlertService.FireAsync("Validación",
        //         $"El total de los abonos (${sumaAbonos:F2}) no coincide con el total de la nota (${totalNota:F2}).",
        //         "warning");
        //     return;
        // }

        try
        {
            if (Id == 0)
            {
                var responseCreate = await SalesNoteService.CreateSaleNoteAsync(saleNote);

                if (responseCreate != null && (responseCreate.Code == 200 || responseCreate.Code == 201) && responseCreate.Data > 0)
                {
                    await SweetAlertService.FireAsync("¡Éxito!", "La nota fue creada correctamente.", "success");
                    NavigationManager.NavigateTo("/Sales/Sale");
                }
                else
                {
                    await SweetAlertService.FireAsync("Error", responseCreate?.Message ?? "Error al crear la nota.", "error");
                }
            }
            else
            {
                var responseUpdate = await SalesNoteService.UpdateSaleNoteAsync(Id, saleNote);

                if (responseUpdate != null && (responseUpdate.Code == 200 || responseUpdate.Code == 201))
                {
                    await SweetAlertService.FireAsync("¡Éxito!", "La nota fue actualizada correctamente.", "success");
                }
                else
                {
                    await SweetAlertService.FireAsync("Error", responseUpdate?.Message ?? "Error al actualizar la nota.", "error");
                }
            }
        }
        catch (Exception ex)
        {
            await SweetAlertService.FireAsync("Excepción", $"Ocurrió un error inesperado: {ex.Message}", "error");
        }
    }
    private void AgregarAccesorio()
    {
        if (nuevoAccesorio.Quantity > 0 && !string.IsNullOrWhiteSpace(nuevoAccesorio.Description))
        {
            nuevoAccesorio.Total = nuevoAccesorio.Quantity * nuevoAccesorio.UnitPrice;
            accesorios.Add(nuevoAccesorio);
            nuevoAccesorio = new();
            CalcularImportes();
        }
    }

    private void AgregarPago()
    {
        if (nuevoPago.AmountPaid > 0 && nuevoPago.RemainingBalance is not null )
        {
            // 🔧 CALCULA el saldo restante aquí
            var saldoRestante = CalcularSaldoRestante();

            SaleNotePayments.Add(new SaleNotePaymentDto
            {
                SaleNoteId = saleNote.SaleNoteId,
                PaymentDate = nuevoPago.PaymentDate == default ? DateTime.Today : nuevoPago.PaymentDate,
                AmountPaid = nuevoPago.AmountPaid,
                RemainingBalance = saldoRestante,
                Notes = nuevoPago.Notes ?? ""
            });

            // Limpia los campos
            nuevoPago = new SaleNotePaymentDto
            {
                PaymentDate = DateTime.Today,
                AmountPaid = 0,
                RemainingBalance = 0,

            };
        }
    }


    private void CalcularImportes()
    {
        saleNoteCurrent.Amount_Accessories = accesorios.Sum(a => a.Total);
        saleNoteCurrent.Amount_Frame ??= 0;
        saleNoteCurrent.Amount_Lens ??= 0;
        saleNoteCurrent.Amount_Service ??= 0;

        var subtotal = (saleNoteCurrent.Amount_Accessories ?? 0)
                     + (saleNoteCurrent.Amount_Frame ?? 0)
                     + (saleNoteCurrent.Amount_Lens ?? 0)
                     + (saleNoteCurrent.Amount_Service ?? 0);

        saleNoteCurrent.Subtotal = subtotal;
        saleNoteCurrent.Discount ??= 0;
        saleNoteCurrent.Total = subtotal - saleNoteCurrent.Discount.Value;
    }


