      <aspNetCore processPath="dotnet" arguments=".\Ovr.ApiServices.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
